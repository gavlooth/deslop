# Project defaults for the deslop CLI.
# Precedence is: explicit CLI flag > environment variable > deslop.toml > built-in default.
# API keys are intentionally not supported here; keep provider secrets in environment variables.

[scan]
# fail_on = "major" # info | minor | major
# baseline = "deslop-baseline.json"

[fix]
# check_cmd = "cargo test --workspace"
# coverage = "disabled" # disabled | auto | auto:<cmd> | lcov:<path> | cloverage:<path> | julia-cov:<path> | coverage-py:<path>
# allow_unverified = false

[slim]
# provider = "anthropic" # anthropic | openai
# model = "claude-sonnet-4-6"
# base_url = "https://api.openai.com/v1" # used by provider = "openai"
# egress_consent = false # true permits real-provider source egress without an interactive prompt

[external]
# clippy = "off" # off | on
# julia_analyzer = "off" # off | staticlint | jet
# julia_project = "julia-env"

[analyzer]
# min_duplication_tokens = 24
# long_method_nloc = 40
# min_meaningful_tokens = 8

# Per-language long-method thresholds override [analyzer].long_method_nloc.
# Supported tables: rust, clojure, julia, python, javascript, typescript, generic.
# [analyzer.rust]
# long_method_nloc = 45
#
# [analyzer.python]
# long_method_nloc = 35
#
# [analyzer.typescript]
# long_method_nloc = 45

# Suppression filters findings after they are produced, by rule and by path.
# Unknown rule names and invalid globs are errors, not silent no-ops.
# disabled_rules = ["magic-number", "narrating-comment"]  # drop these rules everywhere
# ignore_paths = ["**/generated/**", "vendor/**"]         # skip these paths for all rules

# Per-rule controls (rule name -> table). Run `deslop rules` for the rule list.
# [analyzer.rules.long-method]
# enabled = false                                         # disable a single rule
#
# [analyzer.rules.duplicate-block]
# ignore_paths = ["**/tests/**"]                          # skip one rule on these paths
